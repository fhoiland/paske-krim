---
const clueCards = [
  {
    id: 1,
    eyebrow: "Spor 1",
    title: "Peisestuen",
    body: [
      'I asken ligger en halvbrent lapp med teksten "ULIBÅ". Ved siden av peisen står et skilt fra quizkvelden: "Når strømmen svikter, går du ett hakk tilbake."'
    ],
    prompt: "Hva skjuler lappen?",
    options: [
      { value: "nøkkel", label: "Nøkkel" },
      { value: "tyveri", label: "Tyveri" },
      { value: "skibod", label: "Skibod" }
    ],
    submitLabel: "Bekreft spor",
    reveal:
      "Ordet blir TYVERI. Noen ville gi beskjed om at hendelsen skjedde inne i hytta, ikke ute i løypa."
  },
  {
    id: 2,
    eyebrow: "Spor 2",
    title: "Kjøkkenet",
    body: [
      "På benken står tre kopper. Én kopp med kakao er fortsatt lunken og står ved siden av tre ferske appelsinskall.",
      "Ingrid vet at Mats drikker kaffe, Oskar drikker te, og Selma alltid velger kakao når hun er nervøs."
    ],
    prompt: "Hvem lyver om å ikke ha vært innom kjøkkenet?",
    options: [
      { value: "mats", label: "Mats" },
      { value: "selma", label: "Selma" },
      { value: "oskar", label: "Oskar" }
    ],
    submitLabel: "Lås opp neste spor",
    reveal:
      "Den lunkne kakaoen peker rett på Selma. Hun har altså løyet om hvor hun var da lyset blinket."
  },
  {
    id: 3,
    eyebrow: "Spor 3",
    title: "Ved skiboden",
    body: [
      "Snøen er urørt bortsett fra ett ferskt spor som går inn mot hytta. Det finnes ingen ferske fotavtrykk som går ut igjen.",
      "Døren til boden står likevel på gløtt."
    ],
    prompt: "Hva betyr dette for Selmas forklaring om lufteturen?",
    options: [
      { value: "sann", label: "Hun kan fortsatt ha vært ute tidligere" },
      { value: "inne", label: "Hun var inne da tyveriet skjedde" },
      { value: "oskar", label: "Det peker sterkest mot Oskar" }
    ],
    submitLabel: "Tolk sporet",
    reveal:
      "Fotsporene knuser ute-alibiet. Selma var inne, og kunne bevege seg mellom stuen, kjøkkenet og boddøren."
  },
  {
    id: 4,
    eyebrow: "Spor 4",
    title: "Quizheftet",
    body: [
      'I finalerunden ligger Selmas quizark krøllet sammen. På baksiden står det: "Ikke en gang til. Ingen skal vinne det egget foran meg."',
      'Ingrid husker også at Selma tapte med ett poeng i fjor og kalte hele konkurransen "rigget".'
    ],
    prompt: "Hva er det mest sannsynlige motivet?",
    options: [
      { value: "sult", label: "Hun var bare sulten på sjokolade" },
      { value: "sabotere", label: "Hun ville sabotere quizen av stolthet og hevnlyst" },
      { value: "spøk", label: "Hun prøvde bare å lage en uskyldig spøk" }
    ],
    submitLabel: "Fullfør etterforskningen",
    reveal:
      "Notatet viser et tydelig motiv: Selma ville sabotere quizkvelden fordi hun ikke tålte å tape igjen."
  }
];

const suspects = [
  {
    tag: "Mistenkt A",
    name: "Mats",
    description:
      "Hyttekokk med mel på forkléet og kake i ovnen. Han blir fort stresset, men alle kjenner rutinene hans på kjøkkenet."
  },
  {
    tag: "Mistenkt B",
    name: "Selma",
    description:
      "Konkurransemenneske som fortsatt snakker om det bitre tapet i fjor. Hun sier selv at hun 'måtte få luft' akkurat da lyset blinket."
  },
  {
    tag: "Mistenkt C",
    name: "Oskar",
    description:
      "Naboen som elsker dramatikk. Han sier han lette etter te og et gammelt kart, men virker mer fascinert av mysteriet enn av premien."
  }
];

const finalGroups = [
  {
    id: "culprit",
    prompt: "1. Hvem stjal egget?",
    options: [
      { value: "mats", label: "Mats" },
      { value: "selma", label: "Selma" },
      { value: "oskar", label: "Oskar" }
    ]
  },
  {
    id: "motive",
    prompt: "2. Hva var motivet?",
    options: [
      { value: "sabotere", label: "Å sabotere quizkvelden etter fjorårets tap" },
      { value: "sult", label: "Å spise sjokoladen i skjul" },
      { value: "spøk", label: "Å lage en uskyldig practical joke" }
    ]
  },
  {
    id: "hiding",
    prompt: "3. Hvor gjemte hun egget?",
    options: [
      { value: "skibod", label: "I skiboden bak vedsekken" },
      { value: "kjeller", label: "I kjelleren under trappen" },
      { value: "ovn", label: "I ovnen på kjøkkenet" }
    ]
  }
];
---

<main class="relative z-10 mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
  <section class="overflow-hidden rounded-[2rem] border border-stone-700/10 bg-[linear-gradient(135deg,rgba(128,64,31,0.96),rgba(67,43,26,0.9))] p-6 text-amber-50 shadow-[0_18px_45px_rgba(59,33,20,0.18)] sm:p-8">
    <div class="relative">
      <div class="pointer-events-none absolute -left-6 -top-6 h-40 w-40 rotate-[-10deg] opacity-30">
        <div class="absolute left-[22%] top-[18%] h-14 w-14 rounded-full bg-yellow-50"></div>
        <div class="absolute left-[28%] top-[26%] h-1.5 w-1.5 rounded-full bg-stone-900"></div>
        <div class="absolute left-[47%] top-[26%] h-1.5 w-1.5 rounded-full bg-stone-900"></div>
        <div class="absolute left-[37%] top-[37%] h-2.5 w-3 rounded-full bg-orange-300"></div>
        <div class="absolute left-[24%] top-[49%] h-10 w-10 rounded-full bg-yellow-50"></div>
        <div class="absolute left-[21%] top-[68%] h-12 w-14 rounded-[45%] bg-yellow-50"></div>
      </div>
      <div class="pointer-events-none absolute -right-24 -top-16 h-64 w-64 rounded-full bg-yellow-200/25 blur-3xl"></div>

      <span class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-50/90">
        Interaktiv påskekrim
      </span>
      <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight sm:text-5xl">
        Mysteriet på Fjellro Hytte
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-amber-50/90 sm:text-lg">
        Det skulle være en rolig påskekveld med kakao, kryssord og den tradisjonelle hyttequizen.
        Men like før finalerunden forsvinner det forgylte påskeegget som skal deles ut til kveldens
        vinner. For å løse saken må dere sammenligne forklaringer, tolke spor og låse opp nye deler
        av mysteriet.
      </p>

      <div class="mt-5 flex flex-wrap gap-3">
        {["Påskeegg", "Appelsiner", "Hyttekakao", "Vårsol"].map((item) => (
          <span class="rounded-full border border-white/15 bg-amber-50/95 px-4 py-2 text-sm font-medium text-amber-900">
            {item}
          </span>
        ))}
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <div class="rounded-full border border-white/15 bg-white/10 px-4 py-2">
          Løste spor: <span id="progress-count">0</span>/4
        </div>
        <div class="rounded-full border border-white/15 bg-white/10 px-4 py-2">
          Mistanke: <span id="status-text">Saken er helt åpen</span>
        </div>
      </div>

      <div class="mt-5 flex items-end gap-3" aria-hidden="true">
        <span class="egg egg-pink"></span>
        <span class="egg egg-yellow"></span>
        <span class="egg egg-green"></span>
        <span class="egg egg-peach"></span>
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
        <article class="rotate-[-1deg] rounded-[1.6rem] border border-stone-700/10 bg-[linear-gradient(180deg,rgba(255,252,241,0.98),rgba(255,246,225,0.93))] p-5 text-stone-900 shadow-[0_18px_45px_rgba(59,33,20,0.12)]">
          <h2 class="font-serif text-2xl">Oppdrag</h2>
          <p class="mt-3 leading-7 text-stone-700">
            Vertinnen Ingrid hevder at egget ble tatt mellom klokken 19:40 og 19:55, mens lyset
            blinket i hele hytta. Tre personer kan ha gjort det: Selma, Mats og Oskar.
          </p>
          <p class="mt-3 leading-7 text-stone-700">
            Hver riktige konklusjon låser opp neste spor. Til slutt må dere peke ut både skyldig,
            motiv og hvor egget ble gjemt.
          </p>
        </article>

        <article class="rotate-[1deg] rounded-[1.6rem] border border-stone-700/10 bg-[linear-gradient(180deg,rgba(255,252,241,0.98),rgba(255,246,225,0.93))] p-5 text-stone-900 shadow-[0_18px_45px_rgba(59,33,20,0.12)]">
          <h2 class="font-serif text-2xl">Spilleregler</h2>
          <ul class="mt-3 list-disc space-y-2 pl-5 leading-7 text-stone-700">
            <li>Les alle detaljene før dere velger et svaralternativ.</li>
            <li>Dere får ikke neste spor før dere har tolket det forrige riktig.</li>
            <li>Små detaljer i tidslinjen blir viktige senere i saken.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article class="panel-card">
      <span class="section-pill">Tidslinje</span>
      <h2 class="mt-4 font-serif text-3xl text-stone-900">Kvelden slik Ingrid husker den</h2>
      <div class="mt-6 space-y-5">
        {[
          ["19:30", "Alle tre mistenkte er i stuen før quizen starter."],
          ["19:38", "Mats går mot kjøkkenet for å sjekke appelsinkaken."],
          ["19:43", "Selma sier hun går ut for å ta 'en rask luftetur rundt boden'."],
          ["19:47", "Lyset blinker, og Ingrid oppdager senere at påskeegget er borte."],
          ["19:54", "Oskar kommer tilbake med et kart og hevder han lette etter te og stearinlys."]
        ].map(([time, text]) => (
          <div class="border-t border-dashed border-stone-300/70 pt-5 first:border-t-0 first:pt-0">
            <span class="inline-block min-w-16 font-semibold text-orange-800">{time}</span>
            <span class="leading-7 text-stone-700">{text}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="panel-card">
      <span class="section-pill">Bevisoversikt</span>
      <h2 class="mt-4 font-serif text-3xl text-stone-900">Det dere har slått fast</h2>
      <ul id="evidence-list" class="mt-6 list-disc space-y-2 pl-5 leading-7 text-stone-700">
        <li>Ingen sikre bevis ennå. Begynn med første spor.</li>
      </ul>
    </article>
  </section>

  <section class="grid gap-6 lg:grid-cols-2">
    {
      clueCards.map((card, index) => (
        <article
          id={`clue-${card.id}`}
          class:list={[
            "panel-card transition duration-300",
            index > 0 && "locked opacity-50 grayscale-[0.2]"
          ]}
        >
          <span class="section-pill">{card.eyebrow}</span>
          <h2 class="mt-4 font-serif text-3xl text-stone-900">{card.title}</h2>
          <div class="mt-4 space-y-3 leading-7 text-stone-700">
            {card.body.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <p class="mt-4 font-medium text-stone-500">{card.prompt}</p>
          <div class="options mt-5 grid gap-3">
            {card.options.map((option) => (
              <button
                class="option-btn"
                data-group={`clue${card.id}`}
                data-value={option.value}
                type="button"
              >
                {option.label}
              </button>
            ))}
          </div>
          <button class="submit-btn mt-5" data-submit={card.id} type="button">
            {card.submitLabel}
          </button>
          <p class="feedback mt-3 min-h-6 font-semibold" id={`feedback-${card.id}`}></p>
          <div class="reveal-box mt-4 hidden" id={`reveal-${card.id}`}>
            {card.reveal}
          </div>
        </article>
      ))
    }
  </section>

  <section class="panel-card">
    <span class="section-pill">Saksmappe</span>
    <h2 class="mt-4 font-serif text-3xl text-stone-900">Mistenkte</h2>
    <div class="mt-6 grid gap-4 lg:grid-cols-3">
      {
        suspects.map((suspect) => (
          <article class="rounded-[1.6rem] border border-stone-700/10 bg-white/65 p-5 shadow-[0_12px_30px_rgba(59,33,20,0.08)]">
            <span class="inline-flex rounded-full bg-yellow-200/50 px-3 py-1 text-sm font-medium text-yellow-900">
              {suspect.tag}
            </span>
            <h3 class="mt-4 font-serif text-2xl">{suspect.name}</h3>
            <p class="mt-3 leading-7 text-stone-700">{suspect.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article id="final-accusation" class="panel-card locked opacity-50 grayscale-[0.2] transition duration-300">
      <span class="section-pill">Avslør saken</span>
      <h2 class="mt-4 font-serif text-3xl text-stone-900">Hvem gjorde det?</h2>
      <p class="mt-4 leading-7 text-stone-700">
        Når alle fire sporene er løst, må dere konkludere. Dere trenger riktig person, riktig motiv
        og riktig gjemmested for å lukke saken.
      </p>

      <div class="mt-6 grid gap-5">
        {
          finalGroups.map((group) => (
            <section>
              <p class="font-medium text-stone-500">{group.prompt}</p>
              <div class="mt-3 grid gap-3">
                {group.options.map((option) => (
                  <button
                    class="option-btn"
                    data-group={group.id}
                    data-value={option.value}
                    type="button"
                  >
                    {option.label}
                  </button>
                ))}
              </div>
            </section>
          ))
        }
      </div>

      <button id="solve-case" class="submit-btn mt-6" type="button">Lukk saken</button>
      <p id="feedback-final" class="feedback mt-3 min-h-6 font-semibold"></p>
    </article>

    <article class="panel-card">
      <span class="section-pill">Når dere står fast</span>
      <h2 class="mt-4 font-serif text-3xl text-stone-900">Hva saken egentlig krever</h2>
      <ul class="mt-6 list-disc space-y-2 pl-5 leading-7 text-stone-700">
        <li>Først må dere forstå at sporene peker mot et tyveri inne i hytta.</li>
        <li>Deretter må dere avsløre hvem som løy om kjøkkenet.</li>
        <li>Så må dere knuse alibiet om lufteturen ved boden.</li>
        <li>Til slutt må dere koble dette til motivet i quizheftet.</li>
      </ul>
      <div id="case-closed" class="reveal-box mt-6 hidden">
        <strong>Saken er løst:</strong> Selma tok egget, gjemte det i skiboden bak vedsekken og prøvde
        å sabotere quizen fordi hun ikke klarte å tape enda en gang.
      </div>
    </article>
  </section>
</main>

<script is:inline>
  const state = {
    solved: { 1: false, 2: false, 3: false, 4: false },
    selected: {}
  };

  const evidenceItems = [
    "Lappen i peisen varsler om et tyveri som skjedde inne i hytta.",
    "Den lunkne kakaoen avslører at Selma løy om kjøkkenet.",
    "Fotsporene viser at Selma ikke var ute da tyveriet skjedde.",
    "Quiznotatet avslører et hevnmotiv knyttet til fjorårets tap."
  ];

  const answers = { 1: "tyveri", 2: "selma", 3: "inne", 4: "sabotere" };
  const feedbackSuccess = {
    1: "Riktig. Lappen peker mot et planlagt tyveri.",
    2: "Riktig. Selma motsier sporene på kjøkkenet.",
    3: "Riktig. Lufteturen hennes holder ikke.",
    4: "Riktig. Nå har dere både person, alibi-brudd og motiv."
  };
  const feedbackError = {
    1: "Hint: flytt bokstavene ett hakk tilbake i alfabetet.",
    2: "Se på hvem som faktisk drikker kakao når nervene tar over.",
    3: "Snøen lyver ikke. Se på retningen på de ferske fotsporene.",
    4: "Quiznotatet handler ikke om sjokolade, men om stolthet og nederlag."
  };

  const countEl = document.getElementById("progress-count");
  const statusEl = document.getElementById("status-text");
  const evidenceList = document.getElementById("evidence-list");

  function updateProgress() {
    const solvedCount = Object.values(state.solved).filter(Boolean).length;
    countEl.textContent = String(solvedCount);

    if (solvedCount === 0) {
      statusEl.textContent = "Saken er helt åpen";
    } else if (solvedCount < 2) {
      statusEl.textContent = "Noe skurrer rundt Selma";
    } else if (solvedCount < 4) {
      statusEl.textContent = "Selmas forklaring faller fra hverandre";
    } else {
      statusEl.textContent = "Alle spor peker mot Selma";
      document.getElementById("final-accusation")?.classList.remove("locked", "opacity-50", "grayscale-[0.2]");
    }
  }

  function renderEvidence() {
    const solvedIndexes = Object.keys(state.solved).filter((key) => state.solved[key]);

    if (solvedIndexes.length === 0) {
      evidenceList.innerHTML = "<li>Ingen sikre bevis ennå. Begynn med første spor.</li>";
      return;
    }

    evidenceList.innerHTML = solvedIndexes
      .map((key) => `<li>${evidenceItems[Number(key) - 1]}</li>`)
      .join("");
  }

  function setFeedback(id, message, ok) {
    const feedback = document.getElementById(`feedback-${id}`);
    if (!feedback) return;
    feedback.textContent = message;
    feedback.className = `feedback mt-3 min-h-6 font-semibold ${ok ? "text-green-800" : "text-red-800"}`;
  }

  function unlockClue(id) {
    const panel = document.getElementById(`clue-${id}`);
    if (panel) {
      panel.classList.remove("locked", "opacity-50", "grayscale-[0.2]");
    }
  }

  document.querySelectorAll("[data-group]").forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.dataset.group;
      const value = button.dataset.value;
      if (!group || !value) return;

      state.selected[group] = value;
      document.querySelectorAll(`[data-group="${group}"]`).forEach((item) => {
        item.classList.remove("selected-option");
      });
      button.classList.add("selected-option");
    });
  });

  document.querySelectorAll("[data-submit]").forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.dataset.submit;
      if (!id) return;

      const selected = state.selected[`clue${id}`];
      if (!selected) {
        setFeedback(id, "Velg et svaralternativ først.", false);
        return;
      }

      if (selected === answers[id]) {
        state.solved[id] = true;
        setFeedback(id, feedbackSuccess[id], true);
        document.getElementById(`reveal-${id}`)?.classList.remove("hidden");
        unlockClue(Number(id) + 1);
        renderEvidence();
        updateProgress();
      } else {
        setFeedback(id, feedbackError[id], false);
      }
    });
  });

  document.getElementById("solve-case")?.addEventListener("click", () => {
    const culprit = state.selected.culprit;
    const motive = state.selected.motive;
    const hiding = state.selected.hiding;
    const feedback = document.getElementById("feedback-final");

    if (!feedback) return;

    if (!Object.values(state.solved).every(Boolean)) {
      feedback.textContent = "Dere må løse alle fire sporene før dere kan konkludere.";
      feedback.className = "feedback mt-3 min-h-6 font-semibold text-red-800";
      return;
    }

    if (!culprit || !motive || !hiding) {
      feedback.textContent = "Velg svar i alle tre avsluttende kategorier.";
      feedback.className = "feedback mt-3 min-h-6 font-semibold text-red-800";
      return;
    }

    if (culprit === "selma" && motive === "sabotere" && hiding === "skibod") {
      feedback.textContent = "Perfekt. Dere har løst hele påskemysteriet.";
      feedback.className = "feedback mt-3 min-h-6 font-semibold text-green-800";
      document.getElementById("case-closed")?.classList.remove("hidden");
    } else {
      feedback.textContent = "Nesten. Gå gjennom bevisene én gang til og se hva som peker på motiv og gjemmested.";
      feedback.className = "feedback mt-3 min-h-6 font-semibold text-red-800";
    }
  });

  renderEvidence();
  updateProgress();
</script>
