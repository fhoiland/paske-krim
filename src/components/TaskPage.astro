---
import StoryShell from "./StoryShell.astro";
import { hidingSpots, motives, suspects, type TaskMeta, totalTasks } from "../data/bruStory";

interface Props {
  task: TaskMeta;
}

const { task } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const previousHref = task.id > 1 ? `${basePath}oppgave/${task.id - 1}` : basePath;
---

<StoryShell
  title={task.title}
  eyebrow={`Oppgave ${task.id} av ${totalTasks}`}
  kicker={task.scene}
>
  <Fragment slot="lead">
    <p class="mt-4 max-w-3xl text-lg leading-8 text-stone-700">{task.question}</p>
  </Fragment>

  <section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
    <article class="panel-card">
      <span class="section-pill">Etterforskningslogg</span>
      <div id={`story-task-${task.id}`} class="mt-5 space-y-4 leading-8 text-stone-700"></div>

      <div class="mt-6 rounded-[1.6rem] border border-dashed border-orange-300 bg-orange-50/70 p-4">
        <p class="dossier-label">Saksnummer</p>
        <p id={`case-number-${task.id}`} class="mt-2 font-serif text-3xl text-stone-900">Laster sak ...</p>
      </div>
    </article>

    <article class="panel-card">
      <span class="section-pill">Velg riktig spor</span>
      <p id={`prompt-task-${task.id}`} class="mt-5 text-base leading-7 text-stone-700"></p>

      <div id={`options-task-${task.id}`} class="mt-5 grid gap-3"></div>

      <button class="submit-btn mt-5" id={`check-task-${task.id}`} type="button">
        Sjekk svaret
      </button>
      <p class="mt-4 min-h-6 font-semibold" id={`feedback-task-${task.id}`}></p>

      <div class="reveal-box mt-5 hidden" id={`success-task-${task.id}`}>
        <p id={`success-copy-${task.id}`}></p>
        <a
          href={task.nextHref === "/finale" ? `${basePath}finale` : `${basePath}${task.nextHref.replace(/^\//, "")}`}
          class="mt-4 inline-flex rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-800"
        >
          {task.nextLabel}
        </a>
      </div>
    </article>
  </section>

  <section class="panel-card">
    <span class="section-pill">Mistenkte</span>
    <div class="mt-5 grid gap-4 lg:grid-cols-2">
      {suspects.map((suspect) => (
        <article class="dossier-card">
          <p class="font-serif text-2xl text-stone-900">{suspect.name}</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-[0.18em] text-orange-800">{suspect.role}</p>
          <p class="mt-3 text-sm leading-6 text-stone-700">{suspect.style}</p>
          <p class="mt-3 text-sm leading-6 text-stone-600">
            Vanlig spor: <strong>{suspect.clueItem}</strong>
          </p>
        </article>
      ))}
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      basePath,
      previousHref,
      progressKey: "bru-hytte-paskekrim-progress",
      caseKey: "bru-hytte-paskekrim-case",
      caseVersion: 2,
      hidingSpots,
      motives,
      suspects,
      taskId: task.id,
      totalTasks
    }}
  >
    const runtime = window.BruCaseRuntime;
    const caseData = { caseKey, caseVersion, hidingSpots, motives, progressKey, suspects };
    const caseFile = runtime.ensureCase(caseData);
    const progress = runtime.readProgress(progressKey);

    if (!progress.started) {
      runtime.writeProgress(progressKey, { started: true, completed: [] });
    }

    if (taskId > 1 && !progress.completed.includes(taskId - 1)) {
      window.location.href = previousHref;
    }

    const culprit = runtime.findById(suspects, caseFile.culpritId);
    const motive = runtime.findById(motives, caseFile.motiveId);
    const hidingSpot = runtime.findById(hidingSpots, caseFile.hidingSpotId);
    const storyEl = document.getElementById(`story-task-${taskId}`);
    const promptEl = document.getElementById(`prompt-task-${taskId}`);
    const optionsEl = document.getElementById(`options-task-${taskId}`);
    const feedbackEl = document.getElementById(`feedback-task-${taskId}`);
    const successEl = document.getElementById(`success-task-${taskId}`);
    const successCopyEl = document.getElementById(`success-copy-${taskId}`);
    const caseNumberEl = document.getElementById(`case-number-${taskId}`);
    const submitEl = document.getElementById(`check-task-${taskId}`);
    let selected = "";
    let correctAnswer = "";

    caseNumberEl.textContent = `Bru-${caseFile.caseNumber}`;

    function addParagraphs(paragraphs) {
      storyEl.innerHTML = paragraphs.map((paragraph) => `<p>${paragraph}</p>`).join("");
    }

    function addOptions(options) {
      optionsEl.innerHTML = options
        .map(
          (option) =>
            `<button class="option-btn" data-option="${option.value}" type="button">${option.label}</button>`
        )
        .join("");

      optionsEl.querySelectorAll("[data-option]").forEach((button) => {
        button.addEventListener("click", () => {
          selected = button.dataset.option || "";
          optionsEl.querySelectorAll("[data-option]").forEach((item) => item.classList.remove("selected-option"));
          button.classList.add("selected-option");
        });
      });
    }

    if (taskId === 1) {
      correctAnswer = "decoy";
      addParagraphs([
        "Det som ser ut som hovedtyveriet ute på tunet, er bare første lag. Musen løper med små pyntede jakt-egg, mens alle voksne stormer ut i snøen.",
        "Inne i stua ligger silkeduken på premiebordet fortsatt varm, med et tomt ovalt merke der Bru-egget nettopp sto. Smeltet snø drypper på gulvet innenfor døra. Noen brukte kaoset ute som en perfekt avledning."
      ]);
      promptEl.textContent = "Hva er den beste konklusjonen etter å ha sett både bildet og premiebordet inne?";
      addOptions([
        {
          value: "decoy",
          label: "Flukten ute var en avledning mens det ekte Bru-egget ble stjålet inne i hytta"
        },
        {
          value: "outside",
          label: "Musen løp direkte av gårde med selve Bru-egget, og alt skjedde ute på tunet"
        },
        {
          value: "hare",
          label: "Påskeharen ropte fordi han selv mistet kontroll på premien ved et uhell"
        }
      ]);
      successCopyEl.textContent =
        "Nettopp. Nå vet dere at bildet viser avledningen, ikke hele forbrytelsen. Dere må derfor lete etter den som rakk å snike seg inn til premiebordet.";
    }

    if (taskId === 2) {
      correctAnswer = culprit.id;
      addParagraphs([
        `Tilbake ved den tomme sokkelen finner dere ${culprit.clueDetail}. Det er ikke nok til å felle noen alene, men det matcher det ene sporet alle på hytta kjenner igjen.`,
        `Samtidig går dere gjennom alibiene: ${suspects
          .map((suspect) => `${suspect.name} ${suspect.alibi}`)
          .join(". ")}. Ett navn passer urovekkende godt med sporet ved sokkelen.`
      ]);
      promptEl.textContent = "Hvem peker sportsbeviset og alibikaoset tydeligst mot?";
      addOptions(suspects.map((suspect) => ({ value: suspect.id, label: suspect.name })));
      successCopyEl.textContent = `Sporene peker mot ${culprit.name}. Det betyr ikke at hele saken er ferdig, men dere vet nå hvem som utnyttet avledningen best.`;
    }

    if (taskId === 3) {
      correctAnswer = hidingSpot.id;
      addParagraphs([
        `Mellom verandaen og bekken finner dere en ny lapp. Der står det bare: ${caseFile.codedWord}. Ved siden av koden er det risset inn en pil og et lite merke som peker bort fra tunet.`,
        `Det andre sporet er mer fysisk: ${hidingSpot.routeClue}. Sammen peker koden og ruten mot ett bestemt skjulested.`
      ]);
      promptEl.textContent = "Hvor ble Bru-egget mest sannsynlig gjemt?";
      addOptions(hidingSpots.map((spot) => ({ value: spot.id, label: spot.label })));
      successCopyEl.textContent = hidingSpot.revealText;
    }

    if (taskId === 4) {
      correctAnswer = motive.id;
      addParagraphs([
        `I peisen ligger et halvbrent brev med én lesbar linje: "${motive.clueText}"`,
        `Brevet er brettet inn i et programark fra kveldens finale. Det virker skrevet av noen som ikke bare ville ha egget, men også oppnå noe mer med hele stuntet.`
      ]);
      promptEl.textContent = "Hvilket motiv passer best med brevet og opplegget rundt tyveriet?";
      addOptions(motives.map((item) => ({ value: item.id, label: item.label })));
      successCopyEl.textContent = motive.revealText;
    }

    if (progress.completed.includes(taskId)) {
      successEl.classList.remove("hidden");
      feedbackEl.textContent = "Denne oppgaven er allerede løst.";
      feedbackEl.className = "mt-4 min-h-6 font-semibold text-green-800";
    }

    submitEl?.addEventListener("click", () => {
      if (!selected) {
        feedbackEl.textContent = "Velg et svaralternativ først.";
        feedbackEl.className = "mt-4 min-h-6 font-semibold text-red-800";
        return;
      }

      if (selected === correctAnswer) {
        runtime.markCompleted(progressKey, taskId);
        feedbackEl.textContent = "Riktig. Et nytt lag av saken faller på plass.";
        feedbackEl.className = "mt-4 min-h-6 font-semibold text-green-800";
        successEl.classList.remove("hidden");
      } else {
        feedbackEl.textContent = "Ikke helt. Les sporene nøye og prøv igjen.";
        feedbackEl.className = "mt-4 min-h-6 font-semibold text-red-800";
      }
    });
  </script>
</StoryShell>
