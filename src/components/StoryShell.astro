---
interface Props {
  title: string;
  eyebrow?: string;
  kicker?: string;
  showBurst?: boolean;
}

const { title, eyebrow = "Påskekrim", kicker, showBurst = true } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<main class="relative z-10 mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
  <header class="flex flex-wrap items-center justify-between gap-4">
    <a
      href={basePath}
      class="inline-flex items-center gap-2 rounded-full border border-white/50 bg-white/75 px-4 py-2 text-sm font-semibold text-stone-700 shadow-sm backdrop-blur"
    >
      Til forsiden
    </a>
    <span class="section-pill">{eyebrow}</span>
  </header>

  <section class="grid gap-6 lg:grid-cols-[1.02fr_0.98fr]">
    <article class="hero-card min-h-[270px]">
      {kicker && <p class="text-sm font-semibold uppercase tracking-[0.24em] text-orange-900/80">{kicker}</p>}
      <h1 class="mt-3 max-w-3xl font-serif text-4xl leading-tight text-stone-950 sm:text-5xl">{title}</h1>
      <slot name="lead" />
      <div class="mt-6 flex flex-wrap gap-3">
        <span class="case-chip">Påske-kaos</span>
        <span class="case-chip">Bru-egget</span>
        <span class="case-chip">Tilfeldig tyv</span>
        <span class="case-chip">Nye spor hver runde</span>
      </div>
    </article>

    <aside class="image-stage">
      {showBurst && <div class="comic-burst">NEEEIIIIII!!</div>}
      <img
        src={`${basePath}bru-paskekrim.png`}
        alt="Påskekrim ved hytta på Bru med mus, hare og fargerike påskeegg i snøen"
        class="h-full w-full object-cover"
      />
      <div class="image-fade"></div>
    </aside>
  </section>

  <slot />
</main>
