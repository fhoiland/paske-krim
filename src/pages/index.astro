---
import MainLayout from "../layouts/MainLayout.astro";
import StoryShell from "../components/StoryShell.astro";
import {
  agencyNames,
  caseKey,
  caseVersion,
  difficulties,
  hidingSpots,
  motives,
  progressKey,
  settingsKey,
  statsKey,
  storyBranches,
  storyTitle,
  suspectRosters,
  totalTasks
} from "../data/bruStory";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<MainLayout title={storyTitle}>
  <StoryShell title={storyTitle} eyebrow="Ny sak" kicker="Hytta på Bru">
    <Fragment slot="lead">
      <p class="mt-4 max-w-3xl text-lg leading-8 text-stone-700">
        {agencyNames[0]}, {agencyNames[1]} og hele {agencyNames[2]} trenger hjelp. Velg vanskelighetsgrad,
        les briefen, møt de mistenkte og gå videre til saken når du er klar.
      </p>
    </Fragment>

    <section class="grid gap-6">
      <article class="panel-card">
        <span class="section-pill">Forhistorien</span>
        <div id="intro-copy" class="mt-5 space-y-4 leading-8 text-stone-700">
          {storyBranches.family.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="dossier-card">
            <p class="dossier-label">Format</p>
            <p class="mt-2 font-semibold text-stone-900">Forside + briefing + {totalTasks} oppgaver + finale</p>
          </div>
          <div class="dossier-card">
            <p class="dossier-label">Sakstjeneste</p>
            <p class="mt-2 font-semibold text-stone-900">{agencyNames[3]} står klar med kakao og mistanke.</p>
          </div>
          <div class="dossier-card sm:col-span-2 lg:col-span-1">
            <p class="dossier-label">Beste tid på valgt nivå</p>
            <p class="mt-2 font-serif text-3xl text-stone-900" id="best-time-label">Ingen løst ennå</p>
          </div>
        </div>

        <section class="mt-8">
          <div class="flex items-center justify-between gap-3">
            <span class="section-pill">Velg vanskelighetsgrad</span>
            <p class="text-sm font-semibold text-orange-900" id="difficulty-current-label">Laster nivå...</p>
          </div>

          <div class="mt-4 grid gap-3">
            {difficulties.map((difficulty) => (
              <button type="button" class="difficulty-card text-left" data-difficulty={difficulty.id}>
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <p class="font-serif text-2xl text-stone-900">{difficulty.title}</p>
                    <p class="mt-1 text-sm leading-6 text-stone-700">{difficulty.description}</p>
                  </div>
                  <span class="case-chip">{difficulty.shortLabel}</span>
                </div>
                <p class="mt-3 text-sm font-semibold text-orange-900">{difficulty.humor}</p>
              </button>
            ))}
          </div>
        </section>

        <div class="mt-8 flex flex-wrap gap-3">
          <button
            id="start-story"
            type="button"
            class="submit-btn inline-flex items-center justify-center"
          >
            Gå til briefing
          </button>
          <button
            id="continue-story"
            type="button"
            class="hidden rounded-full border border-stone-700/10 bg-white px-5 py-3 text-sm font-semibold text-stone-700 transition hover:bg-stone-50"
          >
            Fortsett saken
          </button>
        </div>
      </article>
    </section>

    <script
      is:inline
      define:vars={{
        basePath,
        caseKey,
        caseVersion,
        difficulties,
        hidingSpots,
        motives,
        progressKey,
        settingsKey,
        storyBranches,
        statsKey,
        suspectRosters,
        totalTasks
      }}
    >
      const runtime = window.BruCaseRuntime;
      const startButton = document.getElementById("start-story");
      const continueButton = document.getElementById("continue-story");
      const difficultyLabel = document.getElementById("difficulty-current-label");
      const bestTimeLabel = document.getElementById("best-time-label");
      const introContainer = document.getElementById("intro-copy");
      const difficultyButtons = Array.from(document.querySelectorAll("[data-difficulty]"));
      const defaultDifficulty = difficulties.find((item) => item.level === 3) || difficulties[0];
      const settings = runtime.readSettings(settingsKey, { difficultyId: defaultDifficulty.id });
      let selectedDifficulty = settings.difficultyId || defaultDifficulty.id;

      function caseDataFor(difficultyId) {
        return {
          caseKey,
          caseVersion,
          difficulties,
          hidingSpots,
          motives,
          progressKey,
          selectedDifficulty: difficultyId,
          suspects: suspectRosters[difficultyId] || suspectRosters[defaultDifficulty.id]
        };
      }

      function nextHref(progress) {
        const nextTask = (progress.completed?.length || 0) + 1;
        if (nextTask > totalTasks) return `${basePath}finale`;
        return `${basePath}oppgave/${nextTask}`;
      }

      function syncDifficultyUi() {
        const active = difficulties.find((item) => item.id === selectedDifficulty) || defaultDifficulty;
        const stats = runtime.readStats(statsKey);
        const best = stats.bestTimes?.[active.id];
        const branch = active.level >= 4 ? storyBranches.adult : storyBranches.family;
        difficultyLabel.textContent = `${active.title} valgt`;
        bestTimeLabel.textContent = best ? runtime.formatDuration(best) : "Ingen løst ennå";
        if (introContainer) {
          introContainer.innerHTML = branch.intro.map((paragraph) => `<p>${paragraph}</p>`).join("");
        }
        difficultyButtons.forEach((button) => {
          const isActive = button.dataset.difficulty === selectedDifficulty;
          button.classList.toggle("selected-difficulty", isActive);
        });
      }

      difficultyButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectedDifficulty = button.dataset.difficulty || defaultDifficulty.id;
          runtime.writeSettings(settingsKey, { difficultyId: selectedDifficulty });
          syncDifficultyUi();
        });
      });

      startButton?.addEventListener("click", () => {
        runtime.resetAll({ caseKey, progressKey, settingsKey });
        runtime.writeSettings(settingsKey, { difficultyId: selectedDifficulty });
        window.location.href = `${basePath}briefing`;
      });

      const progress = runtime.readProgress(progressKey);
      if (progress.started) {
        continueButton?.classList.remove("hidden");
        continueButton?.addEventListener("click", () => {
          const caseFile = runtime.ensureCase(caseDataFor(selectedDifficulty));
          if (caseFile?.difficultyId && caseFile.difficultyId !== selectedDifficulty) {
            runtime.writeSettings(settingsKey, { difficultyId: caseFile.difficultyId });
            selectedDifficulty = caseFile.difficultyId;
            syncDifficultyUi();
          }
          window.location.href = nextHref(progress);
        });
      }

      syncDifficultyUi();
    </script>
  </StoryShell>
</MainLayout>
