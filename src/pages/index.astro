---
import MainLayout from "../layouts/MainLayout.astro";
import StoryShell from "../components/StoryShell.astro";
import {
  caseKey,
  caseVersion,
  hidingSpots,
  introText,
  motives,
  progressKey,
  storyTitle,
  suspects,
  totalTasks
} from "../data/bruStory";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<MainLayout title={storyTitle}>
  <StoryShell title={storyTitle} eyebrow="Ny sak" kicker="Hytta på Bru">
    <Fragment slot="lead">
      <p class="mt-4 max-w-3xl text-lg leading-8 text-stone-700">
        Nå er dette ikke bare en lineær påskekrim lenger. Hver gang du starter en ny sak, får du en
        ny kombinasjon av tyv, motiv og gjemmested.
      </p>
    </Fragment>

    <section class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <article class="panel-card">
        <span class="section-pill">Historien begynner</span>
        <div class="mt-5 space-y-4 leading-8 text-stone-700">
          {introText.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="dossier-card">
            <p class="dossier-label">Format</p>
            <p class="mt-2 font-semibold text-stone-900">Forside + {totalTasks} oppgavesider + finale</p>
          </div>
          <div class="dossier-card">
            <p class="dossier-label">Variasjon</p>
            <p class="mt-2 font-semibold text-stone-900">Tilfeldig tyv, motiv og gjemmested</p>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <button
            id="start-story"
            type="button"
            class="submit-btn inline-flex items-center justify-center"
          >
            Start ny tilfeldig sak
          </button>
          <button
            id="continue-story"
            type="button"
            class="hidden rounded-full border border-stone-700/10 bg-white px-5 py-3 text-sm font-semibold text-stone-700 transition hover:bg-stone-50"
          >
            Fortsett saken
          </button>
        </div>
      </article>

      <article class="panel-card">
        <span class="section-pill">Saksarkiv</span>
        <div class="mt-5 grid gap-4">
          <div class="dossier-card">
            <p class="dossier-label">Mistenkte i omløp</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-stone-700">
              {suspects.map((suspect) => (
                <li><strong>{suspect.name}</strong>: {suspect.role}</li>
              ))}
            </ul>
          </div>

          <div class="dossier-card">
            <p class="dossier-label">Hva kan variere?</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-stone-700">
              <li>{suspects.length} ulike tyver</li>
              <li>{motives.length} ulike motiver</li>
              <li>{hidingSpots.length} ulike skjulesteder</li>
            </ul>
          </div>

          <div class="rounded-[1.6rem] bg-[linear-gradient(135deg,#fff0a6,#ffd867)] p-5 text-stone-900 shadow-inner">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-orange-900">Kampmodus</p>
            <p class="mt-2 font-serif text-3xl leading-tight">
              Nå gjør vi denne skarpere, mer kompleks og mer levende for hver runde.
            </p>
          </div>
        </div>
      </article>
    </section>

    <script
      is:inline
      define:vars={{
        basePath,
        caseKey,
        caseVersion,
        hidingSpots,
        motives,
        progressKey,
        suspects,
        totalTasks
      }}
    >
      const runtime = window.BruCaseRuntime;
      const startButton = document.getElementById("start-story");
      const continueButton = document.getElementById("continue-story");
      const caseData = { caseKey, caseVersion, hidingSpots, motives, progressKey, suspects };

      function nextHref(progress) {
        const nextTask = (progress.completed?.length || 0) + 1;
        if (nextTask > totalTasks) return `${basePath}finale`;
        return `${basePath}oppgave/${nextTask}`;
      }

      startButton?.addEventListener("click", () => {
        runtime.resetCase(caseData);
        window.location.href = `${basePath}oppgave/1`;
      });

      const progress = runtime.readProgress(progressKey);
      if (progress.started) {
        continueButton?.classList.remove("hidden");
        continueButton?.addEventListener("click", () => {
          runtime.ensureCase(caseData);
          window.location.href = nextHref(progress);
        });
      }
    </script>
  </StoryShell>
</MainLayout>
