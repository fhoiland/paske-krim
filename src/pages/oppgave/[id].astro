---
import MainLayout from "../../layouts/MainLayout.astro";
import TaskPage from "../../components/TaskPage.astro";
import { taskMeta } from "../../data/bruStory";

export function getStaticPaths() {
  return taskMeta.map((task) => ({
    params: { id: task.slug },
    props: { task }
  }));
}

const { task } = Astro.props;
---

<MainLayout title={`${task.title} | Påskekrimmen på Bru`}>
  <TaskPage task={task} />
</MainLayout>
