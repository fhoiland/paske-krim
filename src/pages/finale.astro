---
import MainLayout from "../layouts/MainLayout.astro";
import StoryShell from "../components/StoryShell.astro";
import {
  agencyNames,
  caseKey,
  caseVersion,
  difficulties,
  hidingSpots,
  motives,
  progressKey,
  settingsKey,
  statsKey,
  suspectRosters,
  totalTasks
} from "../data/bruStory";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<MainLayout title="Finale | Påskekrimmen på Bru">
  <StoryShell title="Finalen: Hvem tok Bru-egget?" eyebrow="Siste side" kicker="Lukk saken">
    <Fragment slot="lead">
      <p class="mt-4 max-w-3xl text-lg leading-8 text-stone-700">
        Nå må dere samle alt: avledningen, sportsbeviset, kodelappen, tidslinjebruddet og kryssforhøret. Når alle tre
        sluttvalg er riktige, får dere hele avsløringen og kan sende rapporten tilbake til Bruagentene.
      </p>
    </Fragment>

    <section class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <article class="panel-card">
        <span class="section-pill">Sluttrapport</span>
        <div class="mt-5 grid gap-6">
          <section>
            <p class="font-semibold text-stone-700">1. Hvem sto bak tyveriet?</p>
            <div class="mt-3 grid gap-3" data-group="culprit" id="final-culprit-options"></div>
          </section>

          <section>
            <p class="font-semibold text-stone-700">2. Hva var motivet?</p>
            <div class="mt-3 grid gap-3" data-group="motive">
              {motives.map((motive) => (
                <button class="option-btn" data-option={motive.id} type="button">{motive.label}</button>
              ))}
            </div>
          </section>

          <section>
            <p class="font-semibold text-stone-700">3. Hvor ble egget gjemt?</p>
            <div class="mt-3 grid gap-3" data-group="hiding">
              {hidingSpots.map((spot) => (
                <button class="option-btn" data-option={spot.id} type="button">{spot.label}</button>
              ))}
            </div>
          </section>
        </div>

        <button class="submit-btn mt-6" id="solve-finale" type="button">Avslør tyven</button>
        <p class="mt-4 min-h-6 font-semibold" id="final-feedback"></p>

        <div class="reveal-box mt-5 hidden" id="final-success">
          <p id="final-reveal-copy"></p>
          <div class="mt-4 flex flex-wrap gap-3">
            <button
              type="button"
              id="share-report"
              class="inline-flex rounded-full border border-stone-700/10 bg-white px-5 py-3 text-sm font-semibold text-stone-700 transition hover:bg-stone-50"
            >
              Kopier rapport
            </button>
            <button
              type="button"
              id="restart-case"
              class="inline-flex rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-800"
            >
              Start helt ny sak
            </button>
            <button
              type="button"
              id="restart-same-difficulty"
              class="inline-flex rounded-full border border-stone-700/10 bg-white px-5 py-3 text-sm font-semibold text-stone-700 transition hover:bg-stone-50"
            >
              Ny sak på samme nivå
            </button>
          </div>
        </div>
      </article>

      <article class="panel-card">
        <span class="section-pill">Sammendrag</span>
        <div class="mt-5 space-y-4 leading-8 text-stone-700">
          <p id="final-agency-copy"></p>
          <p>
            Når dere starter på nytt, nullstilles saken skikkelig. Ingen gamle spor, ingen hengende lokal
            state og ingen gjenbruk av forrige finale som later som den fortsatt er aktuell.
          </p>
          <div class="dossier-card">
            <p class="dossier-label">Fullført løype</p>
            <p class="mt-2 font-semibold text-stone-900">Avledning, sporrom, kodelapp, tidslinjebrudd, kryssforhør og sluttrapport</p>
          </div>
          <div class="dossier-card">
            <p class="dossier-label">Aktiv vanskelighetsgrad</p>
            <p id="final-difficulty-copy" class="mt-2 font-semibold text-stone-900">Laster nivå ...</p>
          </div>
          <div class="dossier-card">
            <p class="dossier-label">Sakstid</p>
            <p id="final-time-copy" class="mt-2 font-semibold text-stone-900">Laster tid ...</p>
            <p id="final-best-copy" class="mt-2 text-sm font-semibold text-orange-900">Laster rekord ...</p>
          </div>
        </div>
      </article>
    </section>

    <script
      is:inline
      define:vars={{
        agencyNames,
        basePath,
        caseKey,
        caseVersion,
        difficulties,
        hidingSpots,
        motives,
        progressKey,
        settingsKey,
        statsKey,
        suspectRosters,
        totalTasks
      }}
    >
      const runtime = window.BruCaseRuntime;
      const defaultDifficulty = difficulties.find((item) => item.level === 3) || difficulties[0];
      const settings = runtime.readSettings(settingsKey, { difficultyId: defaultDifficulty.id });
      const selectedDifficulty = settings.difficultyId || defaultDifficulty.id;
      const suspects = suspectRosters[selectedDifficulty] || suspectRosters[defaultDifficulty.id];
      const caseData = {
        caseKey,
        caseVersion,
        difficulties,
        hidingSpots,
        motives,
        progressKey,
        selectedDifficulty,
        settingsKey,
        suspects
      };
      const caseFile = runtime.ensureCase(caseData);
      const progress = runtime.readProgress(progressKey);

      if ((progress.completed?.length || 0) < totalTasks) {
        window.location.href = `${basePath}oppgave/${(progress.completed?.length || 0) + 1}`;
      }

      const culprit = runtime.findById(suspects, caseFile.culpritId);
      const motive = runtime.findById(motives, caseFile.motiveId);
      const hidingSpot = runtime.findById(hidingSpots, caseFile.hidingSpotId);
      const difficulty = difficulties.find((item) => item.id === caseFile.difficultyId) || defaultDifficulty;
      const feedback = document.getElementById("final-feedback");
      const revealBox = document.getElementById("final-success");
      const revealCopy = document.getElementById("final-reveal-copy");
      const agencyCopy = document.getElementById("final-agency-copy");
      const difficultyCopy = document.getElementById("final-difficulty-copy");
      const timeCopy = document.getElementById("final-time-copy");
      const bestCopy = document.getElementById("final-best-copy");
      const shareButton = document.getElementById("share-report");
      const culpritOptions = document.getElementById("final-culprit-options");
      const state = { culprit: "", motive: "", hiding: "" };
      let solvedSummary = "";
      let solvedOnce = false;

      agencyCopy.textContent =
        `${agencyNames[(caseFile.caseNumber + 1) % agencyNames.length]} er klare til å arkivere saken, men bare hvis rapporten deres ikke lukter ren gjetting.`;
      difficultyCopy.textContent = `${difficulty.title} | ${difficulty.humor}`;
      timeCopy.textContent = runtime.formatDuration(runtime.elapsedMs(caseFile));
      const currentBest = runtime.readStats(statsKey).bestTimes?.[difficulty.id];
      bestCopy.textContent = currentBest
        ? `Beste tid på dette nivået: ${runtime.formatDuration(currentBest)}`
        : "Ingen registrert rekord på dette nivået ennå.";

      culpritOptions.innerHTML = suspects
        .map((suspect) => `<button class="option-btn" data-option="${suspect.id}" type="button">${suspect.name}</button>`)
        .join("");

      function rankLabel(ms, level) {
        const seconds = Math.floor(ms / 1000);
        if (level === 1) return "Miniagent med gulrotsertifikat";
        if (seconds < 90) return "Bru-legende";
        if (seconds < 150) return "Kripos avdeling Bru";
        if (seconds < 240) return "Skarp sporhund";
        return "Seig, men stødig kodeknekker";
      }

      document.querySelectorAll("[data-group]").forEach((group) => {
        group.querySelectorAll("[data-option]").forEach((button) => {
          button.addEventListener("click", () => {
            state[group.dataset.group] = button.dataset.option || "";
            group.querySelectorAll("[data-option]").forEach((item) => item.classList.remove("selected-option"));
            button.classList.add("selected-option");
          });
        });
      });

      document.getElementById("solve-finale")?.addEventListener("click", () => {
        if (!state.culprit || !state.motive || !state.hiding) {
          feedback.textContent = "Du må velge ett svar i alle tre feltene.";
          feedback.className = "mt-4 min-h-6 font-semibold text-red-800";
          return;
        }

        if (state.culprit === culprit.id && state.motive === motive.id && state.hiding === hidingSpot.id) {
          const elapsed = runtime.elapsedMs(caseFile);
          const result = runtime.recordBestTime(statsKey, difficulty.id, elapsed);
          const rank = rankLabel(elapsed, difficulty.level);
          solvedSummary =
            `Sak Bru-${caseFile.caseNumber} løst på ${runtime.formatDuration(elapsed)}. Rang: ${rank}. ` +
            `Tyv: ${culprit.name}. Motiv: ${motive.label}. Gjemmested: ${hidingSpot.label}.`;
          solvedOnce = true;
          timeCopy.textContent = runtime.formatDuration(elapsed);
          feedback.textContent = "Saken er løst.";
          feedback.className = "mt-4 min-h-6 font-semibold text-green-800";
          revealCopy.textContent =
            `${culprit.name} sto bak tyveriet. Motivet var ${motive.label}, og Bru-egget ble funnet ${hidingSpot.label}. Rang oppnådd: ${rank}. ${result.isRecord ? "Ny rekord på dette nivået." : `Beste tid står fortsatt på ${runtime.formatDuration(result.best)}.`} ${agencyNames[0]} kaller dette en forbilledlig seier for norsk hytteetterforskning.`;
          bestCopy.textContent = `Beste tid på dette nivået: ${runtime.formatDuration(result.best)}`;
          revealBox.classList.remove("hidden");
        } else {
          feedback.textContent = "Nesten. Les gjennom sporene igjen og prøv en ny kombinasjon.";
          feedback.className = "mt-4 min-h-6 font-semibold text-red-800";
        }
      });

      shareButton?.addEventListener("click", async () => {
        if (!solvedOnce || !solvedSummary) {
          feedback.textContent = "Løs saken først før du kopierer rapporten.";
          feedback.className = "mt-4 min-h-6 font-semibold text-red-800";
          return;
        }

        try {
          await navigator.clipboard.writeText(solvedSummary);
          feedback.textContent = "Rapport kopiert til utklippstavlen.";
          feedback.className = "mt-4 min-h-6 font-semibold text-green-800";
        } catch {
          feedback.textContent = solvedSummary;
          feedback.className = "mt-4 min-h-6 font-semibold text-green-800";
        }
      });

      document.getElementById("restart-case")?.addEventListener("click", () => {
        runtime.resetAll({ caseKey, progressKey, settingsKey });
        window.location.href = basePath;
      });

      document.getElementById("restart-same-difficulty")?.addEventListener("click", () => {
        runtime.writeSettings(settingsKey, { difficultyId: difficulty.id });
        runtime.resetCase(caseData);
        window.location.href = `${basePath}oppgave/1`;
      });
    </script>
  </StoryShell>
</MainLayout>
