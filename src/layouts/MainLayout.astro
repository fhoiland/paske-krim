---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Påskekrimmen på hytta på Bru" } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Interaktiv påskekrim ved hytta på Bru bygget med Astro og Tailwind CSS."
    />
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.82),transparent_28%),linear-gradient(180deg,#9dc1ff_0%,#d9e8ff_18%,#eef4ff_30%,#fff5bf_56%,#efcc72_100%)] text-stone-900">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -left-20 top-24 h-64 w-64 rounded-full bg-pink-200/60 blur-3xl"></div>
      <div class="absolute -right-24 bottom-20 h-72 w-72 rounded-full bg-lime-100/70 blur-3xl"></div>
      <div class="snow-layer absolute inset-0 opacity-50"></div>
    </div>
    <slot />
  </body>
</html>
